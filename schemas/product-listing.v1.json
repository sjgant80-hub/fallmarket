{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sjgant80-hub.github.io/fallmarket/schemas/product-listing.v1.json",
  "title": "Product Listing v1",
  "description": "A single item for sale on FallMarket. Can be an SDK, MCP, HTTP API, tool, prompt pack, dataset, or agent-as-service.",
  "type": "object",
  "required": ["v", "id", "seller_did", "kind", "title", "created", "sig"],
  "properties": {
    "v": { "const": 1 },
    "id": {
      "type": "string",
      "description": "Stable listing id · slug or ULID"
    },
    "seller_did": {
      "type": "string",
      "pattern": "^did:key:z[a-km-zA-HJ-NP-Z1-9]+$"
    },
    "kind": {
      "enum": ["sdk", "mcp", "api", "tool", "prompt", "dataset", "service"]
    },
    "title": {
      "type": "string",
      "maxLength": 120
    },
    "subtitle": {
      "type": "string",
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "description": "Long-form markdown"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 20
    },
    "affinity_vector": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 7,
      "maxItems": 7,
      "description": "Seven-axis product affinity for discovery"
    },
    "repo_url": { "type": "string", "format": "uri" },
    "playground_url": { "type": "string", "format": "uri" },
    "docs_url": { "type": "string", "format": "uri" },
    "install": {
      "type": "object",
      "properties": {
        "npm": { "type": "string" },
        "mcp": { "type": "string", "description": "Full `claude mcp add ...` command" },
        "curl": { "type": "string" },
        "docker": { "type": "string" }
      }
    },
    "tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "price_gbp"],
        "properties": {
          "name": { "type": "string", "examples": ["free", "starter", "pro", "enterprise"] },
          "price_gbp": { "type": "number", "minimum": 0 },
          "price_kcc": { "type": "number", "minimum": 0 },
          "includes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "billing": { "enum": ["one-time", "monthly", "per-call", "per-run"] }
        }
      }
    },
    "benchmarks": {
      "type": "array",
      "description": "Reference to standalone benchmark-result documents",
      "items": {
        "type": "object",
        "properties": {
          "suite_id": { "type": "string" },
          "score": { "type": "number" },
          "result_url": { "type": "string", "format": "uri" }
        }
      }
    },
    "provenance_nft": {
      "type": "string",
      "description": "NFT id on the FallColony ledger (optional)"
    },
    "publisher": { "type": "string" },
    "guild": { "type": "string", "description": "deprecated · use `publisher`" },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" },
    "sig": {
      "type": "string",
      "description": "Ed25519 signature by seller_did over canonical JSON (excluding sig)"
    }
  }
}
